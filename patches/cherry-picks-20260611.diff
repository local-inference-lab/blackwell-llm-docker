+    @staticmethod
+    def apply_vocab_mask(logits, vocab_mask):
+        return None
+
+    @staticmethod
+    def set_token_filter(
+        vocab_mask, token_ids, batch_idx, is_allowed=True, reset_vocab_mask=True
+    ):
+        set_token_filter_torch(
