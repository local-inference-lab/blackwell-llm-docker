+def _allowed_token_ids(vocab_mask, token_ids):
+    allowed = []
+    for token_id in token_ids:
+        elem = token_id // 32
+        bit = token_id % 32
+        if int(vocab_mask[0, elem].item()) & (1 << bit):
+            allowed.append(token_id)
+    return allowed
